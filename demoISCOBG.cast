[65.301262, "o", "e_alarm\" \"major_issues\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m actions_enabled   = true\r\n      \u001b[32m+\u001b[0m\u001b[0m alarm_actions     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m alarm_description = \"Major load balancer or worker outage conditions\"\r\n      \u001b[32m+\u001b[0m\u001b[0m alarm_name        = \"ecommerce-major-issues-composite\"\r\n      \u001b[32m+\u001b[0m\u001b[0m alarm_rule        = \"ALARM(ecommerce-major-issues-alb-5xx) OR ALARM(ecommerce-major-issues-target-5xx) OR ALARM(ecommerce-major-issues-unhealthy-hosts)\"\r\n      \u001b[32m+\u001b[0m\u001b[0m arn               = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m id                = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m region            = \"us-east-1\"\r\n      \u001b[32m+\u001b[0m\u001b[0m tags_all          = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Project\" = \"Obligatorio\"\r\n        }\r\n    }\r\n\r\n\u001b[1m  # module.cloudwatch-module.aws_cloudwatch_metric_alarm.alb_5xx_major\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_cloudwatch_metric_alarm\" \"alb_5xx_major\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m actions_enabled                       = true\r\n      \u001b[32m+\u001b[0m\u001b[0m alarm_description                     = \"Major ALB 5xx error rate detected\"\r\n      \u001b[32m+\u001b[0m\u001b[0m alarm_name                            = \"ecommerce-major-issues-alb-5xx\"\r\n      \u001b[32m+\u001b[0m\u001b[0m arn                                   = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m comparison_operator                   = \"GreaterThanThreshold\"\r\n      \u001b[32m+\u001b[0m\u001b[0m datapoints_to_alarm                   = 2\r\n      \u001b[32m+\u001b[0m\u001b[0m dimensions                            = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m evaluate_low_sample_count_percentiles = (known after apply)\r\n     