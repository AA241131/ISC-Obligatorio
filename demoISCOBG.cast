[65.303022, "o", "\r\n\u001b[1m  # module.sec-module.aws_vpc_security_group_ingress_rule.ingreso-lb\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_vpc_security_group_ingress_rule\" \"ingreso-lb\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m arn                    = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m cidr_ipv4              = \"0.0.0.0/0\"\r\n      \u001b[32m+\u001b[0m\u001b[0m from_port              = 80\r\n      \u001b[32m+\u001b[0m\u001b[0m id                     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m ip_protocol            = \"tcp\"\r\n      \u001b[32m+\u001b[0m\u001b[0m region                 = \"us-east-1\"\r\n      \u001b[32m+\u001b[0m\u001b[0m security_group_id      = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m security_group_rule_id = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m tags_all               = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Project\" = \"Obligatorio\"\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m to_port                = 80\r\n    }\r\n"]
[65.30305, "o", "\r\n\u001b[1m  # module.sec-module.aws_vpc_security_group_ingress_rule.ingreso-lb-instancias\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_vpc_security_group_ingress_rule\" \"ingreso-lb-instancias\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m arn                          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m from_port                    = 80\r\n      \u001b[32m+\u001b[0m\u001b[0m id                           = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m ip_protocol                  = \"tcp\"\r\n      \u001b[32m+\u001b[0m\u001b[0m referenced_security_group_id = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m region                       = \"us-east-1\"\r\n      \u001b[32m+\u001b[0m\u001b[0m security_group_id            = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m security_group_rule_id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m tags_all                     = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Project\" = \"Obligatorio\"\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m to_port                      = 80\r\n    }\r\n"]
[65.303075, "o", "\r\n\u001b[1m  # module.vpc-module.aws_internet_gateway.igw\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_internet_gateway\" \"igw\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m arn      = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m id       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m owner_id = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m region   = \"us-east-1\"\r\n      \u001b[32m+\u001b[0m\u001b[0m tags     = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Name\" = \"main-igw\""]
[65.303118, "o", "\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m tags_all = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Name\"    = \"main-igw\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Project\" = \"Obligatorio\"\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m vpc_id   = (known after apply)\r\n    }\r\n"]
[65.303215, "o", "\r\n\u001b[1m  # module.vpc-module.aws_route_table.public_rt\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_route_table\" \"public_rt\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m arn              = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m id               = (known after apply)\r\n"]
[65.303292, "o", "      \u001b[32m+\u001b[0m\u001b[0m owner_id         = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m propagating_vgws = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m region           = \"us-east-1\"\r\n      \u001b[32m+\u001b[0m\u001b[0m route            = [\r\n          \u001b[32m+\u001b[0m\u001b[0m {\r\n              \u001b[32m+\u001b[0m\u001b[0m cidr_block                 = \"0.0.0.0/0\"\r\n              \u001b[32m+\u001b[0m\u001b[0m gateway_id                 = (known after apply)\r\n                \u001b[90m# (12 unchanged attributes hidden)\u001b[0m\u001b[0m\r\n            },\r\n        ]\r\n      \u001b[32m+\u001b[0m\u001b[0m tags             = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Name\" = \"public-rt\"\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m tags_all         = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Name\"    = \"public-rt\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Project\" = \"Obligatorio\"\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m vpc_id           = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # module.vpc-module.aws_route_table_association.public_subnet_assoc1\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_route_table_association\" \"public_subnet_assoc1\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m id             = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m region         = \"us-east-1\"\r\n      \u001b[32m+\u001b[0m\u001b[0m route_table_id = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m subnet_id      = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # module.vpc-module.aws_route_table_association.public_subnet_assoc2\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_route_table_association\" \"public_subnet_assoc2\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m id             = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m region         = \"us-east-1\"\r\n    