[65.2831, "o", "\r\nTerraform used the selected providers to generate the following execution plan. Resource actions are indicated with the following symbols:\r\n  \u001b[32m+\u001b[0m create\u001b[0m\r\n\r\nTerraform will perform the following actions:\r\n\r\n\u001b[1m  # aws_ecr_repository.repo\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_ecr_repository\" \"repo\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m arn                  = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m force_delete         = true\r\n      \u001b[32m+\u001b[0m\u001b[0m id                   = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m image_tag_mutability = \"MUTABLE\"\r\n      \u001b[32m+\u001b[0m\u001b[0m name                 = \"ecommerce\"\r\n      \u001b[32m+\u001b[0m\u001b[0m region               = \"us-east-1\"\r\n      \u001b[32m+\u001b[0m\u001b[0m registry_id          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m repository_url       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m tags                 = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Name\" = \"ecommerce-ecr\"\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m tags_all             = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Name\"    = \"ecommerce-ecr\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Project\" = \"Obligatorio\"\r\n        }\r\n    }\r\n\r\n\u001b[1m  # aws_efs_file_system.uploads\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_efs_file_system\" \"uploads\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m arn                     = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m availability_zone_id    = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m availability_zone_name  = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m creation_token          = \"ecommerce-uploads\"\r\n      \u001b[32m+\u001b[0m\u001b[0m dns_name                = (known after ap