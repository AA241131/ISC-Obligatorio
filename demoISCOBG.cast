[83.540861, "o", "watch_metric_alarm.unhealthy_hosts_major\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_cloudwatch_metric_alarm\" \"unhealthy_hosts_major\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m actions_enabled                       = true\r\n      \u001b[32m+\u001b[0m\u001b[0m alarm_description                     = \"One or more workers are unhealthy\"\r\n      \u001b[32m+\u001b[0m\u001b[0m alarm_name                            = \"ecommerce-major-issues-unhealthy-hosts\"\r\n      \u001b[32m+\u001b[0m\u001b[0m arn                                   = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m comparison_operator                   = \"GreaterThanOrEqualToThreshold\"\r\n      \u001b[32m+\u001b[0m\u001b[0m datapoints_to_alarm                   = 2\r\n      \u001b[32m+\u001b[0m\u001b[0m dimensions                            = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m evaluate_low_sample_count_percentiles = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m evaluation_periods                    = 2\r\n      \u001b[32m+\u001b[0m\u001b[0m id                                    = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m metric_name                           = \"UnHealthyHostCount\"\r\n      \u001b[32m+\u001b[0m\u001b[0m namespace                             = \"AWS/ApplicationELB\"\r\n      \u001b[32m+\u001b[0m\u001b[0m period                                = 60\r\n      \u001b[32m+\u001b[0m\u001b[0m region                                = \"us-east-1\"\r\n      \u001b[32m+\u001b[0m\u001b[0m statistic                             = \"Maximum\"\r\n      \u001b[32m+\u001b[0m\u001b[0m tags_all                              = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Project\" = \"Obligatorio\"\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m threshold                             = 1\r\n      \u001b[32m+\u001b[0m\u001b[0m treat_missing_data                    = \"notBreaching\"\r\n    }\r\n\r\n\u001b[1m  # module.cloudwatch-module.aws_sns_topic.alerts\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_sns_topic\" \"alerts\" {\r\n      \u001b[32m+\u001b[0m\u001b[0m arn                         = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m beginning_archive_time      = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m content_based_deduplication = false\r\n      \u001b[32m+\u001b[0m\u001b[0m fifo_throughput_scope       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m fifo_topic                  = false\r\n      \u001b[32m+\u001b[0m\u001b[0m id                          = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m name                        = \"ecommerce-major-issues-alerts\"\r\n      \u001b[32m+\u001b[0m\u001b[0m name_prefix                 = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m owner                       = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m policy                      = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m region                      = \"us-east-1\"\r\n      \u001b[32m+\u001b[0m\u001b[0m signature_version           = (known after apply)\r\n      \u001b[32m+\u001b[0m\u001b[0m tags                        = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Name\" = \"ecommerce-major-issues-alerts\"\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m tags_all                    = {\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Name\"    = \"ecommerce-major-issues-alerts\"\r\n          \u001b[32m+\u001b[0m\u001b[0m \"Project\" = \"Obligatorio\"\r\n        }\r\n      \u001b[32m+\u001b[0m\u001b[0m tracing_config              = (known after apply)\r\n    }\r\n\r\n\u001b[1m  # module.cloudwatch-module.aws_sns_topic_subscription.admin_email\u001b[0m will be created\r\n\u001b[0m  \u001b[32m+\u001b[0m\u001b[0m resource \"aws_sns_topic_subscription\" \"admin_email\" {\r\n      \u001b[32m+\u001b[0m\u001